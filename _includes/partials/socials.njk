{% css %}
[data-theme="dark"] {
    --svg-color: #9ca3af;
}
[data-theme="light"] {
    --svg-color: #777;
}
.social {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    justify-content: right;
    margin-top: 2rem;
    margin-bottom: 1rem;
}
.social a {
    margin: 0.25rem;
    display: inline-flex;
    align-items: center;
    color: var(--svg-color) !important;
    cursor: pointer;
    transition: color 0.3s;
}
.social a:hover {
    color: var(--link-color-hover) !important;
    transition: color 0.3s;
}
.social .icon {
    width: 1.5rem;
    height: 1.5rem;
}
{% endcss %}

<div class="social">
    <b>Share:</b>
    <a
        href="https://www.facebook.com/sharer/sharer.php?u={{ page.url | absoluteUrl(metadata.url) }}"
        target="_blank"
        rel="noopener"
        aria-label="Share on Facebook (opens new tab)"
    >
        <i class="fa-brands fa-facebook-f icon"></i>
    </a>
    <a
        href="https://www.linkedin.com/sharing/share-offsite/?url={{ page.url | absoluteUrl(metadata.url) }}"
        target="_blank"
        rel="noopener"
        aria-label="Share on LinkedIn (opens new tab)"
    >
        <i class="fa-brands fa-linkedin icon"></i>
    </a>
    <a
        href="https://twitter.com/intent/tweet/?text={{ title }}&url={{ page.url | absoluteUrl(metadata.url) }}"
        target="_blank"
        rel="noopener"
        aria-label="Share on Twitter (opens new tab)"
    >
        <i class="fa-brands fa-twitter icon"></i>
    </a>

    <a
        href="https://bsky.app/intent/compose?text={{ page.url | absoluteUrl(metadata.url) }}"
        target="_blank"
        rel="noopener"
        aria-label="Share on Bluesky (opens new tab)"
    >
        <i class="fa-brands fa-bluesky icon"></i>
    </a>
    <a
        aria-label="Copy page link to clipboard"
        onclick="copyUrlToClipboard()"
        role="link"
    >
        <i class="fa-solid fa-link icon"></i>
    </a>
</div>