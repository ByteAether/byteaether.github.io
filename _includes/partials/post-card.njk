{% css %}
.post-card
{
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
}

.post-card h2 {
    margin-top: 0;
    margin-bottom: 0;
}
{% endcss %}

<div class="post-card">
    <h2><a href="{{ post.url }}">{% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}</a></h2>
    <div class="excerpt"><em>{{ post | excerpt | truncate(500) }}</em></div>
    {% include "./post-meta.njk" %}
</div>