{% css "common" %}
footer {
    position: sticky;
    bottom: 0;
    margin-top: 1rem;
	padding: 0.5em;
    background-color: var(--bg-color-secondary);
    transition: background-color 0.3s;
    box-shadow: 0 -2px 4px var(--shadow-color);
    z-index: 1000;
}
@media(max-height: 480px) {
    footer {
        position: relative;
    }
}

.footer-container {
    display: flex;
	flex-wrap: wrap;
	align-items: center;
    gap: 0 1rem;
    
    max-width: 70em;
    margin-left: auto;
    margin-right: auto;
    
    font-weight: bold;
}

.footer-container a {
    color: var(--text-color);
    font-size: 1.5rem;
    transition: color 0.3s;
}
{% endcss %}

<footer>
    <div class="footer-container">
        <div><a href="https://github.com/ByteAether" title="{{ metadata.title }}" target="_blank"><i class="fa-brands fa-github"></i></a></div>
        <div>ByteAether 2025</div>
    </div>
</footer>